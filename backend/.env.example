# ── Server ────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Frontend origin allowed by CORS
CORS_ORIGIN=http://localhost:5173

# ── Certificate issuance ────────────────────────────────────────────────────
# mock            -> no real cert, dev only (refused in production)
# registration-key-> Check Point registration key flow (recommended)
# p12             -> PKCS#12 file flow (verify JHF level for your version)
CERT_ISSUANCE_MODE=mock

# Require manual approval before issuing (true/false)
REQUIRE_APPROVAL=false

# One-time download / password-reveal token lifetime (seconds)
DOWNLOAD_TOKEN_TTL_SECONDS=900

# ── Check Point Management API ──────────────────────────────────────────────
CP_MGMT_HOST=
CP_MGMT_PORT=443
CP_MGMT_USER=
CP_MGMT_PASSWORD=
# Optional: use an API key instead of user/password
CP_MGMT_API_KEY=
# Verify the management server TLS certificate (MUST be true in production)
CP_MGMT_TLS_VERIFY=true
# For Multi-Domain Security Management (leave empty for standalone)
CP_MGMT_DOMAIN=

# User identity source: internal (local DB) | ldap (use ICA management tool)
CP_USER_MANAGEMENT=internal
# Registration key validity window (days)
CP_REGKEY_EXPIRATION_DAYS=14
# Optional certificate validity (days); leave empty for ICA default
CP_CERT_VALIDITY_DAYS=

# ── SMTP (доставка пароля к .p12) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DOGMA <no-reply@dogma.local>

# ── Admin vault (хранение паролей .p12 для админа) ──────────────────────────
# Ключ шифрования: 64 hex-символа (32 байта). Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_VAULT_KEY=4dfc8798eed2f104b7727844c0f56625622c55c22e3939f4dcc98b27eb9527c4
# Токен доступа к admin API (передаётся в заголовке X-Admin-Token)
ADMIN_API_TOKEN=qwertyuiopASDFGHJKLzxcvbnm

# ── Аутентификация (SSO) ────────────────────────────────────────────────────
# dev  -> вход имитируется (только не в production)
# oidc -> реальный провайдер (Azure AD/Entra, Keycloak, ADFS, Okta...)
AUTH_MODE=dev
FRONTEND_URL=http://localhost:5173
# Секрет подписи сессионной cookie (смените на длинную случайную строку)
SESSION_SECRET=change-me-to-a-long-random-string

# ── VPN / подписки ──────────────────────────────────────────────────────────
# Срок действия подписки по умолчанию (дней)
VPN_DEFAULT_TTL_DAYS=30
# Лимит трафика по умолчанию (ГБ); оставьте пустым, чтобы не ограничивать
VPN_DEFAULT_TRAFFIC_LIMIT_GB=

# ── Промежуточный сервер (Россия) ───────────────────────────────────────────
# Хост бэкенда/промежуточного сервера, через который клиенты ходят к нодам
RU_INTERMEDIATE_HOST=
RU_INTERMEDIATE_SSH_PORT=22
RU_INTERMEDIATE_SSH_USER=root
# Путь к приватному SSH-ключу ИЛИ base64-ключ (если оба пусты — деплой невозможен)
RU_INTERMEDIATE_SSH_KEY_PATH=
RU_INTERMEDIATE_SSH_KEY_BASE64=

# ── Деплой нод (Hysteria2 / WireGuard) ──────────────────────────────────────
HYSTERIA_DOCKER_IMAGE=tobyxdd/hysteria-server:v2
# Подсеть для WG-туннеля между промежуточным сервером и нодами
WG_TUNNEL_NETWORK=10.200.200.0/24
# Порт, на котором WG слушает на нодах
WG_LISTEN_PORT=51820

# Параметры OIDC (нужны только при AUTH_MODE=oidc)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
